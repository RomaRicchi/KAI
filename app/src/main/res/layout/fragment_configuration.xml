<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_light_green"
    tools:context=".ui.perfil.ConfigurationFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/layout_configuration_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingHorizontal="20dp"
        android:paddingBottom="28dp"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/configuration_title"
                android:textColor="@color/kai_text_main"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/configuration_subtitle"
                android:textColor="@color/kai_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/configuration_experience"
                android:textColor="@color/kai_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/kai_card_bg"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_notifications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50dp"
                        android:text="@string/config_notifications"
                        android:textOff=""
                        android:textOn=""
                        android:textColor="@color/kai_text_main"
                        android:textSize="16sp"
                        app:showText="false"
                        app:useMaterialThemeColors="true" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_sounds"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50dp"
                        android:text="@string/config_sounds"
                        android:textOff=""
                        android:textOn=""
                        android:textColor="@color/kai_text_main"
                        android:textSize="16sp"
                        app:showText="false"
                        app:useMaterialThemeColors="true" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_show_streaks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50dp"
                        android:text="@string/config_show_streaks"
                        android:textOff=""
                        android:textOn=""
                        android:textColor="@color/kai_text_main"
                        android:textSize="16sp"
                        app:showText="false"
                        app:useMaterialThemeColors="true" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_emotional_messages"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50dp"
                        android:text="@string/config_emotional_messages"
                        android:textOff=""
                        android:textOn=""
                        android:textColor="@color/kai_text_main"
                        android:textSize="16sp"
                        app:showText="false"
                        app:useMaterialThemeColors="true" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_discrete_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50dp"
                        android:text="@string/config_discrete_mode"
                        android:textOff=""
                        android:textOn=""
                        android:textColor="@color/kai_text_main"
                        android:textSize="16sp"
                        app:showText="false"
                        app:useMaterialThemeColors="true" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_lock_pin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50dp"
                        android:text="@string/config_lock_pin"
                        android:textOff=""
                        android:textOn=""
                        android:textColor="@color/kai_text_main"
                        android:textSize="16sp"
                        app:showText="false"
                        app:useMaterialThemeColors="true" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/configuration_kai"
                android:textColor="@color/kai_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/kai_card_bg"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/config_kai_intensity"
                        app:boxBackgroundColor="@color/kai_card_bg"
                        app:boxStrokeColor="@color/kai_primary"
                        app:endIconTint="@color/kai_primary"
                        app:hintTextColor="@color/kai_text_secondary">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/dropdown_intensity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:paddingHorizontal="16dp"
                            android:textColor="@color/kai_text_main"
                            android:textSize="16sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_reminder_time"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/config_reminder_time"
                        android:textAllCaps="false"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/ic_clock_24"
                        app:iconGravity="textStart"
                        app:strokeColor="@color/kai_primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_configuration"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="22dp"
                android:text="@string/config_save"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:backgroundTint="@color/kai_primary"
                app:cornerRadius="8dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progress_bar_configuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
